import java.util.*;
 class firstclass{
    public static void main(String args[]){
        Scanner sc=new Scanner(System.in);
        int a=sc.nextInt();
        int b=sc.nextInt();
        int button=sc.nextInt();
        int sum=a+b;
        int multi=a*b;
        int div=a%b;
        switch(button){
            case 1: System.out.print(sum);
            break;
            case 2:
                if (a>b){
                    int diff1=a-b;
                    System.out.print(diff1);
                } else{
                    int diff2=b-a;
                    System.out.print(diff2);
                }break;
            case 3:System.out.print(multi);
            break;
            case 4:System.out.print(div);
            break;
        }}
}
